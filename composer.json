{
    "name": "pianotell/flarum-ext-flamoji",
    "description": "Simple emoji manager for Flarum. Maintained fork of the-turk/flarum-flamoji (discontinued) with fixes for https://forum.pianotell.com/.",
    "keywords": [
        "flarum",
        "emoji",
        "picker"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Navindra Umanee",
            "email": "navindra@cs.mcgill.ca",
            "homepage": "https://www.cs.mcgill.ca/~navindra/",
            "role": "Fork maintainer"
        },
        {
            "name": "Hasan Özbey",
            "email": "hasanoozbey@gmail.com",
            "homepage": "https://github.com/the-turk",
            "role": "Original author"
        }
    ],
    "support": {
        "issues": "https://github.com/PrimateCoder/flarum-flamoji/issues",
        "source": "https://github.com/PrimateCoder/flarum-flamoji"
    },
    "require": {
        "php": ">=8.1",
        "flarum/core": "^1.8.0"
    },
    "conflict": {
        "clarkwinkelmann/flarum-ext-emojionearea": "*",
        "the-turk/flarum-flamoji": "*"
    },
    "autoload": {
        "psr-4": {
            "PianoTell\\Flamoji\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Flamoji",
            "category": "feature",
            "icon": {
                "name": "far fa-smile-wink",
                "backgroundColor": "#b72a2a",
                "color": "#fff"
            },
            "database-support": [
                "mysql",
                "mariadb"
            ]
        },
        "flarum-cli": {
            "modules": {
                "admin": true,
                "forum": true,
                "js": true,
                "jsCommon": true,
                "css": true,
                "gitConf": true,
                "githubActions": true,
                "prettier": true,
                "typescript": false,
                "bundlewatch": false,
                "backendTesting": false,
                "editorConfig": true,
                "styleci": true
            }
        }
    }
}
