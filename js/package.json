{
  "name": "@pianotell/flarum-ext-flamoji",
  "description": "Simple emoji manager for Flarum. This fork includes fixes for https://forum.pianotell.com/.",
  "license": "MIT",
  "version": "0.0.0",
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "copy-webpack-plugin": "^11.0.0",
    "emoji-mart": "^5.6.0",
    "file-saver": "2.0.5",
    "flarum-webpack-config": "^3.0.0",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1"
  },
  "devDependencies": {
    "@flarum/prettier-config": "^1.0.0",
    "prettier": "^2.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/primatecoder/flarum-flamoji.git"
  },
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "build-dev": "webpack --mode development --config webpack.config.js",
    "format": "prettier --write src",
    "format-check": "prettier --check src",
    "analyze": "cross-env ANALYZER=true npm run build"
  },
  "private": true,
  "prettier": "@flarum/prettier-config"
}